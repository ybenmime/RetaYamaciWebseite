# WhatsApp Cloud API Credentials
# Alle Werte aus dem Meta Developer Dashboard ausfüllen

# Permanent Token aus Meta Business Suite → System Users
WHATSAPP_TOKEN=

# Phone Number ID aus WhatsApp Developer Console → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=

# Retas WhatsApp-Nummer (Format: Ländercode + Nummer, kein + oder Leerzeichen)
# Beispiel: 4915112345678 für +49 151 12345678
RECIPIENT_PHONE_NUMBER=

# Port für den lokalen Server
PORT=3001
